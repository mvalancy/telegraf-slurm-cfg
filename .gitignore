# Editor / OS noise
*.swp
*~
.DS_Store

# Never commit secrets or local Telegraf output blocks
*.local.conf
secrets.conf

# Generated local test report (captures the live host's name + versions).
# NOTE: the committed Docker reports under test/reports/ are intentionally kept.
/report.html

# Slurm job stdout files (created by sbatch in the working dir)
slurm-*.out

# Build output (run ./build.sh to regenerate)
/dist/
*.tar.gz

# Intermediate matrix record (docker-matrix.sh rebuilds it + index.html)
/test/reports/.matrix.tsv

# Python bytecode (e.g. from preview-dashboards.py)
__pycache__/
*.pyc
